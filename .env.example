# ============================================================
# 环境变量示例 —— 复制为 .env 后填入真实值
#   cp .env.example .env
# 注意：.env 切勿提交到 git（已在 .gitignore 中忽略）
# ============================================================

# ---------- 阿里云百炼（DashScope OpenAI 兼容接口） ----------
# 在百炼控制台获取：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# OpenAI 兼容模式的基础地址，固定值，无需修改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- 模型 ----------
# 对话大模型（仅用国内模型，经百炼调用）
LLM_MODEL=qwen3.6-plus
# 向量模型（百炼 text-embedding-v3，输出 1024 维）
EMBED_MODEL=text-embedding-v3
# 单次模型输出与 Agent 工具回环上限
LLM_MAX_OUTPUT_TOKENS=2048
AGENT_MAX_STEPS=30
MAX_MODEL_CALLS_PER_REQUEST=4
MAX_RETRIEVAL_CALLS_PER_REQUEST=3
# 按供应商账单币种填写每百万 Token 单价；0 表示仅统计 Token、不估算费用。
LLM_INPUT_COST_PER_MILLION=0
LLM_OUTPUT_COST_PER_MILLION=0

# ---------- LangSmith 可观测（可选，留空则不上报） ----------
LANGSMITH_API_KEY=
# 开启链路追踪（true / false）
LANGCHAIN_TRACING_V2=false
# LangSmith 项目名
LANGCHAIN_PROJECT=enterprise-kb
# 显式治理门：只有审批、远端权限/保留策略确认和以下参数全部有效时才允许开启。
LANGSMITH_ORG_APPROVED=false
LANGSMITH_APPROVAL_REFERENCE=
LANGSMITH_REMOTE_POLICY_CONFIRMED=false
LANGSMITH_TRACING_SAMPLING_RATE=0.0
LANGSMITH_WORKSPACE_ID=
LANGSMITH_ENDPOINT=
LANGSMITH_DATA_REGION=disabled
LANGSMITH_RETENTION_DAYS=14
# 独立的追踪 HMAC 密钥，生产至少 32 个随机字符；不得与 JWT/API Key 复用。
LANGSMITH_REDACTION_SECRET=

# ---------- 应用 ----------
# 运行环境：development / production
APP_ENV=development
# 服务监听地址与端口
APP_HOST=127.0.0.1
APP_PORT=8000
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# readiness 单组件超时，不触发模型调用。
READINESS_TIMEOUT_SECONDS=3

# ---------- 身份认证 ----------
# 由企业身份系统与本服务共同持有的 HS256 密钥；生产环境至少 32 个随机字符。
# 禁止使用示例值，且本服务不提供 Token 签发接口。
AUTH_JWT_SECRET=replace_with_at_least_32_random_characters
AUTH_JWT_ISSUER=enterprise-idp
AUTH_JWT_AUDIENCE=enterprise-kb

# ---------- 请求、并发与每日预算 ----------
MAX_QUESTION_CHARS=4000
MAX_SESSION_ID_CHARS=64
QA_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=10
ADMIN_RATE_LIMIT_PER_MINUTE=60
QA_MAX_CONCURRENCY=8
UPLOAD_MAX_CONCURRENCY=2
ADMIN_MAX_CONCURRENCY=10
DAILY_USER_MODEL_CALLS=200
DAILY_TENANT_MODEL_CALLS=5000
DAILY_USER_TOKEN_BUDGET=500000
DAILY_TENANT_TOKEN_BUDGET=10000000

# ---------- 上传与解析安全 ----------
MAX_FILENAME_CHARS=200
MAX_FILE_SIZE_BYTES=52428800
UPLOAD_CHUNK_BYTES=1048576
UPLOAD_WRITE_TIMEOUT_SECONDS=30
FILE_VALIDATION_TIMEOUT_SECONDS=30
PARSER_TIMEOUT_SECONDS=120
PARSER_WORKERS=2
MAX_ARCHIVE_ENTRIES=2000
MAX_ARCHIVE_UNCOMPRESSED_BYTES=104857600
MAX_ARCHIVE_COMPRESSION_RATIO=100
MAX_PDF_PAGES=500
MAX_XLSX_SHEETS=100
MAX_XLSX_CELLS=1000000
MAX_PARSED_CHARS=2000000
# 预留恶意软件扫描接口；生产接入扫描器后设为 true。
MALWARE_SCAN_REQUIRED=false

# ---------- 持久化摄入 Worker ----------
INGEST_JOB_MAX_ATTEMPTS=3
INGEST_JOB_LEASE_SECONDS=300
INGEST_JOB_POLL_SECONDS=2
INGEST_JOB_RETRY_BASE_SECONDS=30
INGEST_WORKER_CONCURRENCY=1

# ---------- 会话、审计与人工介入 ----------
CHECKPOINT_DB_PATH=storage/checkpoints.db
CONVERSATION_TTL_DAYS=30
CONVERSATION_MAX_MESSAGES=100
CONVERSATION_LEASE_SECONDS=300
CONVERSATION_CLEANUP_BATCH=200
AUDIT_WRITE_RETRIES=3
SENSITIVE_RULES_PATH=config/sensitive_rules.json

# ---------- 生产部署（Nginx / HTTPS） ----------
# 以下变量由 Nginx 容器/docker-compose.prod.yml 读取，不属于 Python Settings：
# DOMAIN=your-domain.example.com
# SSL_CERT_PATH=nginx/ssl/cert.pem
# SSL_KEY_PATH=nginx/ssl/key.pem

# ---------- 运营通知（企业微信群机器人） ----------
# 企业微信机器人 Webhook URL，留空则不发通知
# 配置方法：在企业微信群 → 群机器人 → 添加机器人 → 复制 Webhook 地址
WECHAT_WORK_WEBHOOK_URL=
